generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// For local SQLite dev, uncomment below and comment out above:
// datasource db {
//   provider = "sqlite"
//   url      = "file:./dev.db"
// }

// ── Enums ─────────────────────────────────────────────────────

enum QuestType {
  MAIN
  SIDE
  CHALLENGE
}

enum ActivityType {
  EXPERIMENT
  PROJECT
  BUILD
  MODEL
  COOKING
  FIELDSTUDY
  SURVEY
}

enum SideQuestType {
  EXPERIMENT
  JOURNALING
  REALWORLDTASK
  DRAWING
  BUILDING
  INTERVIEW
  FIELDTRIP
  GAME
  PUZZLE
}

enum XpSourceType {
  LESSON
  QUEST
  SIDEQUEST
  ACTIVITY
  REFLECTION
  STREAK
  BONUS
}

enum ContentType {
  THEME
  QUEST
  LESSON
  ACTIVITY
  SIDEQUEST
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

enum UserRole {
  ADMIN
  TEACHER
  PARENT
  LEARNER
}

// ── Core Entities ─────────────────────────────────────────────

model Guild {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  logoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  themes        Theme[]
  learnerProfiles LearnerProfile[]
  users         User[]
}

model User {
  id            String    @id @default(uuid())
  guildId       String
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(LEARNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  guild         Guild     @relation(fields: [guildId], references: [id])
  learnerProfile LearnerProfile?
  accounts      Account[]
  sessions      Session[]
  reflections   Reflection[]
  parentLinks   ParentChild[] @relation("ParentUsers")
  childLinks    ParentChild[] @relation("ChildUsers")
}

model LearnerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  guildId       String
  grade         Int
  dateOfBirth   DateTime?
  displayName   String
  avatarUrl     String?
  totalXp       Int      @default(0)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  lastActivityDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
  guild         Guild    @relation(fields: [guildId], references: [id])
  progress      Progress[]
  xpRecords     XpRecord[]
  badges        Badge[]
  streaks       Streak[]
  wallet        StudentWallet?
  avatar        StudentAvatar?
  emotionalCheckins EmotionalCheckin[]
  inventory     StudentInventory[]
  coinTracking  CoinAwardTracking[]
}

// ── NextAuth Tables ──────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Content Hierarchy ────────────────────────────────────────

model Theme {
  id              String   @id @default(uuid())
  guildId         String
  title           String
  slug            String   @unique
  description     String?
  coverImage      String?
  durationWeeks   Int
  drivingQuestion String?
  grade           Int
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  guild           Guild    @relation(fields: [guildId], references: [id])
  quests          Quest[]
  sideQuests      SideQuest[]
  activities      Activity[]
  themeSubjects   ThemeSubject[]
}

model ThemeSubject {
  id        String @id @default(uuid())
  themeId   String
  subject   String

  theme     Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([themeId, subject])
}

model Quest {
  id              String   @id @default(uuid())
  themeId         String
  title           String
  slug            String
  description     String?
  questType       QuestType @default(MAIN)
  orderIndex      Int       @default(0)
  coverImage      String?
  xpReward        Json      @default("{\"base\": 100}")
  cbcMapping      Json?
  estimatedDurationMinutes Int?
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  theme           Theme    @relation(fields: [themeId], references: [id])
  lessons         Lesson[]
  sideQuests      SideQuest[]
  activities      Activity[]
  progress        Progress[]

  @@unique([themeId, slug])
}

model Lesson {
  id              String   @id @default(uuid())
  questId         String
  title           String
  slug            String
  description     String?
  contentBlocks   Json     @default("[]")
  cbcMapping      Json?
  difficulty      Json     @default("{\"complexityScore\": 2}")
  xpReward        Json     @default("{\"base\": 50}")
  estimatedDurationMinutes Int?
  orderIndex      Int      @default(0)
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quest           Quest    @relation(fields: [questId], references: [id])
  activities      Activity[]
  progress        Progress[]

  @@unique([questId, slug])
}

model SideQuest {
  id              String   @id @default(uuid())
  questId         String?
  themeId         String
  title           String
  slug            String
  description     String?
  sideQuestType   SideQuestType @default(JOURNALING)
  activityBlocks  Json     @default("[]")
  cbcMapping      Json?
  difficulty      Json     @default("{\"complexityScore\": 2}")
  xpReward        Json     @default("{\"base\": 75}")
  estimatedDurationMinutes Int?
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quest           Quest?   @relation(fields: [questId], references: [id])
  theme           Theme    @relation(fields: [themeId], references: [id])
  progress        Progress[]
  activities      Activity[]

  @@unique([themeId, slug])
}

model Activity {
  id              String   @id @default(uuid())
  lessonId        String?
  questId         String?
  sideQuestId     String?
  themeId         String
  title           String
  description     String?
  activityType    ActivityType @default(EXPERIMENT)
  materialsList   Json     @default("[]")
  toolsList       Json     @default("[]")
  procedureSteps  Json     @default("[]")
  cbcMapping      Json?
  difficulty      Json     @default("{\"complexityScore\": 2}")
  xpReward        Json     @default("{\"base\": 100}")
  estimatedDurationMinutes Int?
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson          Lesson?  @relation(fields: [lessonId], references: [id])
  quest           Quest?   @relation(fields: [questId], references: [id])
  sideQuest       SideQuest? @relation(fields: [sideQuestId], references: [id])
  theme           Theme    @relation(fields: [themeId], references: [id])
  progress        Progress[]
}

// ── Progress & Gamification ──────────────────────────────────

model Progress {
  id              String   @id @default(uuid())
  learnerId       String
  lessonId        String?
  questId         String?
  sideQuestId     String?
  activityId      String?
  masteryPercent  Int      @default(0)
  lastAccessed    DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])
  lesson          Lesson?  @relation(fields: [lessonId], references: [id])
  quest           Quest?   @relation(fields: [questId], references: [id])
  sideQuest       SideQuest? @relation(fields: [sideQuestId], references: [id])
  activity        Activity? @relation(fields: [activityId], references: [id])

  @@index([learnerId])
  @@index([lessonId])
  @@index([questId])
}

model XpRecord {
  id              String   @id @default(uuid())
  learnerId       String
  sourceType      XpSourceType
  sourceId        String
  amount          Int
  description     String?
  awardedAt       DateTime @default(now())

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])

  @@index([learnerId])
  @@index([awardedAt])
}

model Badge {
  id              String   @id @default(uuid())
  learnerId       String
  badgeType       String
  name            String
  description     String?
  imageUrl        String?
  awardedAt       DateTime @default(now())

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])

  @@index([learnerId])
  @@unique([learnerId, badgeType])
}

model Streak {
  id              String   @id @default(uuid())
  learnerId       String
  streakType      String   @default("daily_learning")
  currentCount    Int      @default(0)
  lastDate        DateTime @default(now())
  bestCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])

  @@unique([learnerId, streakType])
}

// ── Reflections / Journal ────────────────────────────────────

model Reflection {
  id              String   @id @default(uuid())
  learnerId       String
  userId          String
  lessonId        String?
  questId         String?
  sideQuestId     String?
  themeId         String?
  entryType       String   @default("reflection")
  prompt          String?
  response        Json?
  competencyEvidence Json  @default("[]")
  valueEvidence   Json     @default("[]")
  tags            Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@index([learnerId])
  @@index([userId])
}

// ── CBC Reference Data ───────────────────────────────────────

model CbcStrand {
  id              String   @id @default(uuid())
  subject         String
  name            String

  @@unique([subject, name])
}

model CbcCompetency {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
}

model CbcValue {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
}

model CbcPci {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
}

// ── Parent-Child Linking ──────────────────────────────────────

model ParentChild {
  id             String   @id @default(uuid())
  parentId       String
  childUserId    String
  createdAt      DateTime @default(now())

  parent         User     @relation("ParentUsers", fields: [parentId], references: [id])
  childUser      User     @relation("ChildUsers", fields: [childUserId], references: [id])

  @@unique([parentId, childUserId])
  @@index([parentId])
  @@index([childUserId])
}

// ── Spark Coins & Shop Enums ─────────────────────────────────

enum WalletTransactionType {
  EARNED
  SPENT
  BONUS
  ADJUSTMENT
}

enum WalletTransactionSource {
  LESSON
  QUEST
  REFLECTION
  THEME
  STREAK
  SHOP_PURCHASE
  PARENT_REWARD
  BONUS
  ADJUSTMENT
}

enum AvatarItemCategory {
  BASE_AVATAR
  HAIR
  CLOTHING
  HATS
  SHOES
  GLASSES
  ACCESSORIES
  LEARNING_TOOLS
  BACKGROUNDS
  PETS
}

enum AvatarItemRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum AvatarUnlockType {
  ALWAYS_AVAILABLE
  COINS_ONLY
  LESSON_COUNT
  QUEST_COUNT
  STREAK_DAYS
  XP_THRESHOLD
  BADGE_COUNT
}

// ── Spark Coins & Shop Models ───────────────────────────────

model StudentWallet {
  id              String   @id @default(uuid())
  learnerId       String   @unique
  balance         Int      @default(0)
  lifetimeEarned  Int      @default(0)
  lifetimeSpent   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])
  transactions    CoinTransaction[]
  @@index([learnerId])
}

model CoinTransaction {
  id              String   @id @default(uuid())
  walletId        String
  amount          Int
  type            WalletTransactionType
  source          WalletTransactionSource
  sourceId        String?
  description     String?
  balanceAfter    Int      @default(0)
  createdAt       DateTime @default(now())

  wallet          StudentWallet @relation(fields: [walletId], references: [id])
  @@index([walletId])
  @@index([createdAt])
}

model StudentAvatar {
  id                    String   @id @default(uuid())
  learnerId             String   @unique
  baseAvatar            String   @default("default")
  skinTone              String   @default("medium")
  hairStyle             String   @default("short")
  hairColor             String   @default("brown")
  faceExpression        String   @default("smile")
  equippedHatId         String?
  equippedTopId         String?
  equippedBottomId      String?
  equippedShoesId       String?
  equippedGlassesId     String?
  equippedAccessoryId   String?
  equippedToolId        String?
  equippedPetId         String?
  equippedBackgroundId  String?
  updatedAt             DateTime @updatedAt

  learner               LearnerProfile @relation(fields: [learnerId], references: [id])
  @@index([learnerId])
}

model AvatarItem {
  id                    String   @id @default(uuid())
  name                  String
  description           String?
  category              AvatarItemCategory
  price                 Int      @default(0)
  rarity                AvatarItemRarity @default(COMMON)
  emoji                 String   @default("🎁")
  iconUrl               String?
  layerImageUrl         String?
  previewImageUrl       String?
  isActive              Boolean  @default(true)
  unlockType            AvatarUnlockType @default(ALWAYS_AVAILABLE)
  unlockRequirement     Int      @default(0)
  unlockDescription     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  inventory             StudentInventory[]
}

model StudentInventory {
  id              String   @id @default(uuid())
  learnerId       String
  avatarItemId    String
  equipped        Boolean  @default(false)
  purchasedAt     DateTime @default(now())

  avatarItem      AvatarItem @relation(fields: [avatarItemId], references: [id])
  learner         LearnerProfile @relation(fields: [learnerId], references: [id])
  @@unique([learnerId, avatarItemId])
  @@index([learnerId])
}

model RewardRule {
  id              String   @id @default(uuid())
  action          String   @unique
  coins           Int      @default(0)
  xp              Int      @default(0)
  dailyLimit      Int      @default(0)
  isActive        Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CoinAwardTracking {
  id              String   @id @default(uuid())
  learnerId       String
  sourceType      String
  sourceId        String
  awardedAt       DateTime @default(now())

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])
  @@unique([learnerId, sourceType, sourceId])
  @@index([learnerId])
}

enum EmotionType {
  HAPPY
  CALM
  CURIOUS
  OKAY
  SAD
  WORRIED
  TIRED
  FRUSTRATED
}

model EmotionalCheckin {
  id              String       @id @default(uuid())
  learnerId       String
  emotion         EmotionType
  emotionLabel    String
  note            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  learner         LearnerProfile @relation(fields: [learnerId], references: [id])
  @@index([learnerId])
  @@index([createdAt])
}

model Homework {
  id              String   @id @default(uuid())
  parentId        String
  learnerId       String
  title           String
  subject         String?
  focusArea       String?
  instructions    String?
  linkedLessonId  String?
  dueDate         DateTime?
  completedAt     DateTime?
  status          String   @default("assigned")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([parentId])
  @@index([learnerId])
}
